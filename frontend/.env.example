# Frontend Environment Variables
VITE_API_URL=https://api.example.com/api/v1

# ── Sentry — error tracking ───────────────────────────────────
# Leave VITE_SENTRY_DSN empty to disable Sentry (safe for local dev).
VITE_SENTRY_DSN=
# Fraction of page loads to trace in Sentry Performance (0.0 = off)
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
