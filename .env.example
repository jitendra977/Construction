# ============================================================
#  ConstructPro — Environment Template
#  Copy to backend/.env and fill in real values.
#  NEVER commit .env to version control.
#
#  Generate SECRET_KEY:
#    python -c "import secrets; print(secrets.token_hex(50))"
# ============================================================

# ── Image tagging (set by deploy script automatically) ──────
IMAGE_TAG=latest

# ── Django ──────────────────────────────────────────────────
# REQUIRED — no default, container refuses to start without this
SECRET_KEY=generate-with-python-secrets-token-hex-50

DJANGO_ENV=production
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ── Admin user (created on first container start) ───────────
# REQUIRED on first deploy — no fallback default
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me-strong-password

# ── CSRF / trusted origins ───────────────────────────────────
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# ── Security: cookies (True in production, False in local dev) ──
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ── HSTS (enable after confirming HTTPS is stable) ───────────
# Start with 3600 seconds, then increase to 31536000 (1 year)
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# ── Database (PostgreSQL) ────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=constructpro
DB_USER=constructpro
DB_PASSWORD=strong-db-password-here
DB_HOST=db
DB_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=strong-redis-password-here
REDIS_URL=redis://:strong-redis-password-here@redis:6379/0

# ── Email (SMTP) ─────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=ConstructPro <noreply@yourdomain.com>

# ── Media URL (must match your frontend domain) ──────────────
MEDIA_URL=https://yourdomain.com/media/

# ── Frontend ─────────────────────────────────────────────────
VITE_API_URL=https://api.yourdomain.com/api/v1

# ── Sentry (optional) ────────────────────────────────────────
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ── AI / Assistant (optional) ────────────────────────────────
# OPENAI_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_VISION_API_KEY=

# ── Storage (optional — S3/Cloudflare R2) ───────────────────
# USE_S3=True
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_ENDPOINT_URL=https://your-r2-account.r2.cloudflarestorage.com

# ── VPS SSH (used by deploy.sh) ─────────────────────────────
VPS_USER=nishanaweb
VPS_HOST=nishanaweb.cloud
REMOTE_PROJECT_DIR=/home/nishanaweb/project/Construction
DEPLOY_BRANCH=main

# ============================================================
#  LOCAL DEV OVERRIDES (put these in backend/.env for local)
# ============================================================
# DEBUG=True
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False
# CORS_ALLOW_ALL_ORIGINS=True
# ALLOWED_HOSTS=localhost,127.0.0.1,192.168.0.112
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
