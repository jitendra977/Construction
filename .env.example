# ============================================================
#  ConstructPro — Environment Template
#  Copy to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# ── Image tagging (set by deploy script automatically) ──────
IMAGE_TAG=latest

# ── Django ──────────────────────────────────────────────────
SECRET_KEY=change-me-use-python-secrets-token-hex-50
DJANGO_ENV=production
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ── Database (PostgreSQL) ────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=constructpro
DB_USER=constructpro
DB_PASSWORD=strong-db-password-here
DB_HOST=db
DB_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=strong-redis-password-here
REDIS_URL=redis://:strong-redis-password-here@redis:6379/0

# ── Email (SMTP) ─────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password

# ── Frontend ─────────────────────────────────────────────────
VITE_API_URL=https://yourdomain.com/api/v1

# ── Storage (optional — S3/Cloudflare R2) ───────────────────
# USE_S3=True
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_ENDPOINT_URL=https://your-r2-account.r2.cloudflarestorage.com

# ── VPS SSH (used by deploy.sh) ─────────────────────────────
VPS_USER=nishanaweb
VPS_HOST=nishanaweb.cloud
REMOTE_PROJECT_DIR=/home/nishanaweb/project/Construction
DEPLOY_BRANCH=deploy-server
