# ============================================================
#  ConstructPro Backend — .env.example
#  Copy to .env and fill in real values before deploying.
# ============================================================

# ── Django Core ───────────────────────────────────────────────
SECRET_KEY=your-secure-production-key-here
DEBUG=False
DJANGO_ENV=production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost

# ── CORS & CSRF ────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Security ──────────────────────────────────────────────────
SECURE_SSL_REDIRECT=False

# ── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# ── PostgreSQL ────────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=constructpro
DB_USER=constructpro
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0

# ── Email (Gmail SMTP) ────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=youremail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=youremail@gmail.com
SUPPORT_EMAIL=support@yourdomain.com

# ── File Uploads ──────────────────────────────────────────────
FILE_UPLOAD_MAX_MEMORY_SIZE=52428800
DATA_UPLOAD_MAX_MEMORY_SIZE=52428800

# ── Admin Seed ────────────────────────────────────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_PASSWORD=change-me-strong-password

# ── Observability / Sentry ────────────────────────────────────
# Leave SENTRY_DSN empty to disable Sentry entirely (safe for local dev).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Fraction of requests to trace in Sentry Performance (0.0 = off, 1.0 = all)
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.0

# ── Logging ───────────────────────────────────────────────────
# Use LOG_FORMAT=json in production for structured log parsing.
# Use LOG_FORMAT=text in development for human-readable output.
LOG_FORMAT=text

# ── GitHub Actions CI/CD Deployment Token ──────────────────────
# Required to trigger one-click GitOps deployments from the dashboard.
# Generate a token at: https://github.com/settings/tokens
# GITHUB_DEPLOY_TOKEN=your_github_personal_access_token_here

# ── AI Integrations (Groq & Gemini) ───────────────────────────
# Used for daily logs assistant, translation, and chat companion features.
# Leave empty to run the app without AI modules.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Text-to-Speech (ElevenLabs) ────────────────────────────────
# Optional: used for auditory feedback and accessibility features.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB


